# ─────────────────────────────────────────────────────────────
#  CrytiXSnare — Environment Configuration
#  Copy this file to .env.local and edit as needed
# ─────────────────────────────────────────────────────────────

# Demo Mode: set to "true" to run with realistic mock data
# No Supabase account needed — perfect for demos and CV
VITE_DEMO_MODE=true

# ─────────────────────────────────────────────────────────────
#  OPTIONAL — only needed if connecting a real Supabase project
# ─────────────────────────────────────────────────────────────
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VITE_API_URL=http://localhost:8000
